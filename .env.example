# Database
DATABASE_URL="postgresql://user:password@localhost:5432/riseandshinehrm?schema=public"

# Email Configuration
RESEND_API_KEY=your_resend_api_key_here
EMAIL_FROM=noreply@riseandshinehrm.com

# When OTP send/store fails (e.g. missing otp_codes table), these emails can still log in with code 123456. Comma-separated.
ADMIN_FALLBACK_EMAIL=aaronsiam21@gmail.com,kazi@siyam.nyc,tisha@riseandshine.nyc,cary@riseandshine.nyc

# Canonical production domain for public-facing links
# In Vercel production environment variables, set this to: https://riseandshinehrm.com
# Even if this is missing, production code will default to https://riseandshinehrm.com
NEXT_PUBLIC_BASE_URL=https://riseandshinehrm.com

# Node Environment (optional)
NODE_ENV=development

# 15-minute interview reminder (admin emails). On Vercel Hobby, use GitHub Actions (.github/workflows/interview-reminders.yml) which runs every 5 min.
INTERVIEW_REMINDER_RECIPIENTS=aaronsiam21@gmail.com,kazi@siyam.nyc
INTERVIEW_REMINDER_MINUTES=15
# Required in production: cron routes return 503 if unset. Same value in Vercel and GitHub Secrets for interview-reminders workflow.
CRON_SECRET=long_random_string

# Mobile app → HRM sync: shared secret for POST /api/mobile/sync/time-entry (Bearer token or X-HRM-Sync-Key header)
MOBILE_SYNC_SECRET=

# Address autocomplete (Mapbox). Used by /api/mapbox/autocomplete and /api/mapbox/details.
NEXT_PUBLIC_MAPBOX_TOKEN=
