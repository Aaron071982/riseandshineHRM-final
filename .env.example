# Database
DATABASE_URL="postgresql://user:password@localhost:5432/riseandshinehrm?schema=public"

# Supabase pooler only: max connections per Prisma instance (default is 8 in dev, 1 in prod).
# Set to 1 if you hit MaxClientsInSessionMode; raise in local dev if the dashboard times out on pool fetch.
# PRISMA_CONNECTION_LIMIT=8

# Email Configuration
RESEND_API_KEY=your_resend_api_key_here
EMAIL_FROM=noreply@riseandshinehrm.com

# When OTP send/store fails (e.g. missing otp_codes table), these emails can still log in with code 123456. Comma-separated.
ADMIN_FALLBACK_EMAIL=aaronsiam21@gmail.com,kazi@siyam.nyc,tisha@riseandshine.nyc,cary@riseandshine.nyc

# Billing portal-only users (auto-provisioned on first successful OTP). Optional extra emails beyond lib/billing-portal-users.ts.
# BILLING_PORTAL_EMAILS=someone@riseandshineaba.com

# Who can open Billing + Payroll (nav, pages, APIs). Overrides default allowlist in lib/constants.ts.
# BILLING_MANAGER_EMAILS=aaronsiam21@gmail.com,kazi@siyam.nyc,kazi@riseandshineaba.com,fardeenhassansardar12@gmail.com,shaziakhaliq37@gmail.com

# Canonical production domain for public-facing links and OAuth metadata.
# Vercel redirects riseandshinehrm.com → www.riseandshinehrm.com (non-www → www).
# Set this to the DESTINATION host (with www). Code also auto-normalizes bare domain in production.
NEXT_PUBLIC_BASE_URL=https://www.riseandshinehrm.com

# Node Environment (optional)
NODE_ENV=development

# 15-minute interview reminder (admin emails).
INTERVIEW_REMINDER_RECIPIENTS=aaronsiam21@gmail.com,kazi@siyam.nyc
INTERVIEW_REMINDER_MINUTES=15
#
# SETUP REQUIRED:
# 1. Set CRON_SECRET in Vercel Dashboard:
#    Project -> Settings -> Environment Variables
#    -> Add: CRON_SECRET = [any random string]
# 2. Vercel automatically signs cron requests
#    with this secret - no other config needed
# 3. Do NOT set this in GitHub secrets anymore
#    as GitHub Actions crons are now disabled
CRON_SECRET=long_random_string

# Scheduled cron email jobs (onboarding nudges, interview reminders, staleness digest, etc.).
# Off by default. Set to true only when you want Vercel crons to send mail again.
# AUTOMATIC_EMAILS_ENABLED=true

# OTP test accounts (hrmtesting@, aaronsiam22@, aaronsiam24@) use fixed code 000000 only on
# localhost / non-production. In production they receive real emailed OTPs like all users.

# Mobile app → HRM sync: shared secret for POST /api/mobile/sync/time-entry (Bearer token or X-HRM-Sync-Key header)
MOBILE_SYNC_SECRET=

# Dedicated bearer token for Claude MCP connector (generate: openssl rand -hex 32)
MCP_API_KEY=

# Address autocomplete (Mapbox). Used by /api/mapbox/autocomplete and /api/mapbox/details.
NEXT_PUBLIC_MAPBOX_TOKEN=
