// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  RBT
  CANDIDATE
  BCBA
  BILLING
  MARKETING
  CALL_CENTER
  DEV
}

enum PreferredContactMethod {
  EMAIL
  TEXT
  CALL
}

enum RBTStatus {
  NEW
  REACH_OUT
  REACH_OUT_EMAIL_SENT
  TO_INTERVIEW
  INTERVIEW_SCHEDULED
  INTERVIEW_COMPLETED
  HIRED
  STALLED
  REJECTED
}

enum InterviewStatus {
  SCHEDULED
  COMPLETED
  NO_SHOW
  CANCELED
}

enum InterviewDecision {
  PENDING
  OFFERED
  REJECTED
}

enum OnboardingTaskType {
  DOWNLOAD_DOC
  UPLOAD_SIGNED_DOC
  VIDEO_COURSE
  TRAINING_LINK
  SIGNATURE
  PACKAGE_UPLOAD
  FORTY_HOUR_COURSE_CERTIFICATE
}

enum ShiftStatus {
  SCHEDULED
  COMPLETED
  CANCELED
}

enum TimeEntrySource {
  MOBILE_APP
  WEB_MANUAL
}

enum SignatureStatus {
  SIGNED
  MISSING
  NA
}

enum LeaveType {
  SICK
  VACATION
  PERSONAL
  OTHER
}

enum LeaveRequestStatus {
  PENDING
  APPROVED
  DENIED
}

enum EmailTemplateType {
  REACH_OUT
  INTERVIEW_INVITE
  OFFER
  REJECTION
  MISSING_ONBOARDING
}

enum OnboardingDocumentType {
  ACKNOWLEDGMENT
  FILLABLE_PDF
}

enum OnboardingCompletionStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

enum ApplicationSource {
  ADMIN_CREATED
  PUBLIC_APPLICATION
}

enum Ethnicity {
  WHITE
  ASIAN
  BLACK
  HISPANIC
  SOUTH_ASIAN
  MIDDLE_EASTERN
}

enum ActivityType {
  PAGE_VIEW
  LINK_CLICK
  BUTTON_CLICK
  FORM_SUBMISSION
  LOGIN
  LOGOUT
}

// Employee types for filtering (Dev team is represented by DevTeam/DevTeamMember)
enum EmployeeType {
  RBT
  BCBA
  BILLING
  MARKETING
  CALL_CENTER
  DEV
}

enum DocumentStatus {
  ACTIVE
  EXPIRED
  REPLACED
}

enum DocumentType {
  OFFER_LETTER
  EMPLOYMENT_AGREEMENT
  CONTRACTOR_AGREEMENT
  NDA
  HIPAA_ACK
  CONFIDENTIALITY
  NON_COMPETE
  W4
  I9
  DIRECT_DEPOSIT
  BACKGROUND_CHECK
  CPR_CERT
  TB_CLEARANCE
  RBT_40_HR_CERT
  RBT_COMPETENCY_ASSESSMENT
  BCBA_CERTIFICATE
  MALPRACTICE_POLICY
  CAQH_CONFIRMATION
  CREDENTIALING_APPROVAL_LETTER
}

enum CredentialType {
  BACB_ID
  RBT_CERT
  BCBA_CERT
  STATE_LICENSE
  NPI
  MEDICAID_PROVIDER_ID
  CAQH_ID
  MALPRACTICE_INSURANCE
}

enum CredentialVerificationStatus {
  UNVERIFIED
  VERIFIED
  REJECTED
}

enum ServiceLocation {
  IN_HOME
  CLINIC
  TELEHEALTH
  SCHOOL
  COMMUNITY
}

enum SupervisionType {
  DIRECT_OBSERVATION
  CLIENT_MEETING
  PARENT_TRAINING
  TEAM_MEETING
  OTHER
}

enum ComplianceAlertType {
  DOC_EXPIRING
  CREDENTIAL_EXPIRING
  UNDER_SUPERVISION_5_PERCENT
  AUTH_EXPIRING
  AUTH_EXHAUSTED
}

enum ComplianceSeverity {
  INFO
  WARN
  BLOCKER
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
}

// For StaffHoursLog: which type of profile/member the log refers to
enum StaffHoursLogType {
  BCBA
  BILLING
  MARKETING
  CALL_CENTER
  DEV_TEAM_MEMBER
}

model User {
  id          String   @id @default(cuid())
  name        String?
  phoneNumber String?  @unique
  email       String?  @unique
  role        UserRole @default(CANDIDATE)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  rbtProfile               RBTProfile?
  profile                  UserProfile?
  sessions                 Session[]
  activities               ActivityLog[]
  interviewScorecards      InterviewScorecard[]
  employees                Employee[]           @relation("UserEmployee")
  employmentDocuments      EmploymentDocument[] @relation("UserEmploymentDocuments")
  verifiedCredentials      Credential[]         @relation("UserVerifiedCredentials")
  createdClinicalLogs      ClinicalServiceLog[] @relation("UserCreatedClinicalLogs")
  createdSupervisionEvents SupervisionEvent[]   @relation("UserCreatedSupervisionEvents")
  resolvedComplianceAlerts ComplianceAlert[]    @relation("UserResolvedComplianceAlerts")
  auditLogs                AuditLog[]           @relation("UserAuditLogs")

  @@map("users")
}

model UserProfile {
  id                           String                  @id @default(cuid())
  userId                       String                  @unique
  fullName                     String?
  preferredName                String?
  phone                        String?
  address                      String?
  timezone                     String?
  preferredContactMethod       PreferredContactMethod?
  bio                          String?                 @db.Text
  skills                       String[]
  languages                    String[]
  emergencyContactName         String?
  emergencyContactRelationship String?
  emergencyContactPhone        String?
  employeeId                   String?
  startDate                    DateTime?
  department                   String?
  title                        String?
  rbtCertificationNumber       String?
  rbtCertificationExpiresAt    DateTime?
  themePreference              String? // "light" | "dark" | "system"
  createdAt                    DateTime                @default(now())
  updatedAt                    DateTime                @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

model Session {
  id           String    @id @default(cuid())
  userId       String
  token        String    @unique
  expiresAt    DateTime
  device       String?
  browser      String?
  ipAddress    String?
  lastActiveAt DateTime?
  createdAt    DateTime  @default(now())
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model OtpCode {
  id          String   @id @default(cuid())
  phoneNumber String?
  email       String?
  code        String
  expiresAt   DateTime
  createdAt   DateTime @default(now())
  used        Boolean  @default(false)

  @@index([phoneNumber, code])
  @@index([email, code])
  @@map("otp_codes")
}

model RBTProfile {
  id                       String             @id @default(cuid())
  userId                   String             @unique
  firstName                String
  lastName                 String
  phoneNumber              String
  email                    String?
  locationCity             String?
  locationState            String?
  zipCode                  String?
  addressLine1             String?
  addressLine2             String?
  preferredServiceArea     String?
  notes                    String?
  gender                   String?
  ethnicity                Ethnicity?
  fortyHourCourseCompleted Boolean            @default(false)
  status                   RBTStatus          @default(NEW)
  scheduleCompleted        Boolean            @default(false)
  source                   ApplicationSource? @default(ADMIN_CREATED)
  submittedAt              DateTime?
  resumeUrl                String?            @db.Text
  resumeFileName           String?
  resumeMimeType           String?
  resumeSize               Int?
  availabilityJson         Json?
  languagesJson            Json?
  experienceYears          Int?
  experienceYearsDisplay   String?
  preferredAgeGroupsJson   Json?
  authorizedToWork         Boolean?
  canPassBackgroundCheck   Boolean?
  cprFirstAidCertified     String?
  transportation           Boolean?
  preferredHoursRange      String?
  schedulingToken          String?            @unique
  createdAt                DateTime           @default(now())
  updatedAt                DateTime           @updatedAt

  user                  User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  interviews            Interview[]
  onboardingTasks       OnboardingTask[]
  shifts                Shift[]
  timeEntries           TimeEntry[]
  leaveRequests         LeaveRequest[]
  interviewEmailLogs    InterviewEmailLog[]
  availabilitySlots     AvailabilitySlot[]
  documents             RBTDocument[]
  interviewNotes        InterviewNotes[]
  onboardingCompletions OnboardingCompletion[]
  auditLogs             RBTAuditLog[]
  clientAssignments     ClientAssignment[]
  sessionNotes          SessionNote[]

  @@map("rbt_profiles")
}

// Scheduling: clients (e.g. for RBT–client matching and assignments)
model SchedulingClient {
  id                    String   @id @default(cuid())
  name                  String
  addressLine1          String?
  addressLine2          String?
  city                  String?
  state                 String?
  zip                   String?
  preferredRbtEthnicity String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  assignments ClientAssignment[]

  @@map("scheduling_clients")
}

// RBT–client assignment: which days and time range (e.g. Mon/Tue/Wed 4–7 PM)
model ClientAssignment {
  id                 String   @id @default(cuid())
  rbtProfileId       String
  schedulingClientId String
  daysOfWeek         Int[] // 0=Sunday, 1=Monday, ..., 6=Saturday
  timeStart          String? // e.g. "16:00" or "4:00 PM"
  timeEnd            String? // e.g. "19:00" or "7:00 PM"
  notes              String?  @db.Text
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  rbtProfile RBTProfile       @relation(fields: [rbtProfileId], references: [id], onDelete: Cascade)
  client     SchedulingClient @relation(fields: [schedulingClientId], references: [id], onDelete: Cascade)

  @@index([rbtProfileId])
  @@index([schedulingClientId])
  @@map("client_assignments")
}

model Interview {
  id                   String            @id @default(cuid())
  rbtProfileId         String
  scheduledAt          DateTime
  durationMinutes      Int               @default(30)
  interviewerName      String
  status               InterviewStatus   @default(SCHEDULED)
  decision             InterviewDecision @default(PENDING)
  meetingUrl           String?
  notes                String?
  reminderSentAt       DateTime?
  reminder_15m_sent_at DateTime?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  rbtProfile     RBTProfile           @relation(fields: [rbtProfileId], references: [id], onDelete: Cascade)
  interviewNotes InterviewNotes?
  scorecards     InterviewScorecard[]

  @@index([reminder_15m_sent_at])
  @@map("interviews")
}

model InterviewEmailLog {
  id           String            @id @default(cuid())
  rbtProfileId String
  templateType EmailTemplateType
  sentAt       DateTime          @default(now())
  toEmail      String
  subject      String
  status       String?
  body         String?           @db.Text

  rbtProfile RBTProfile @relation(fields: [rbtProfileId], references: [id], onDelete: Cascade)

  @@map("interview_email_logs")
}

model OnboardingTask {
  id                  String             @id @default(cuid())
  rbtProfileId        String
  taskType            OnboardingTaskType
  title               String
  description         String?            @db.Text
  documentDownloadUrl String?            @db.Text
  uploadUrl           String?            @db.Text
  isCompleted         Boolean            @default(false)
  completedAt         DateTime?
  sortOrder           Int                @default(0)
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  rbtProfile RBTProfile @relation(fields: [rbtProfileId], references: [id], onDelete: Cascade)

  @@index([rbtProfileId, isCompleted])
  @@map("onboarding_tasks")
}

model Shift {
  id              String      @id @default(cuid())
  rbtProfileId    String
  clientName      String
  clientId        String?
  startTime       DateTime
  endTime         DateTime
  locationAddress String?
  status          ShiftStatus @default(SCHEDULED)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  rbtProfile  RBTProfile  @relation(fields: [rbtProfileId], references: [id], onDelete: Cascade)
  timeEntries TimeEntry[]

  @@map("shifts")
}

model TimeEntry {
  id                         String           @id @default(cuid())
  rbtProfileId               String
  shiftId                    String?
  clockInTime                DateTime
  clockOutTime               DateTime?
  totalHours                 Float?
  source                     TimeEntrySource  @default(WEB_MANUAL)
  signatureStatus            SignatureStatus?
  signatureImageUrl          String?          @db.Text
  guardianName               String?
  signedAt                   DateTime?
  guardianUnavailableReason  String?
  guardianUnavailableNote    String?          @db.Text
  notes                      String?          @db.Text
  mobileClockEventIdClockIn  String?
  mobileClockEventIdClockOut String?
  latitude                   Float?
  longitude                  Float?
  createdAt                  DateTime         @default(now())
  updatedAt                  DateTime         @updatedAt

  rbtProfile  RBTProfile   @relation(fields: [rbtProfileId], references: [id], onDelete: Cascade)
  shift       Shift?       @relation(fields: [shiftId], references: [id], onDelete: SetNull)
  sessionNote SessionNote?

  @@unique([mobileClockEventIdClockIn, mobileClockEventIdClockOut])
  @@map("time_entries")
}

model SessionNote {
  id                String    @id @default(cuid())
  timeEntryId       String    @unique
  rbtProfileId      String
  summary           String?   @db.Text
  whereServicesWere String?   @db.Text
  whosInvolved      String?   @db.Text
  goalsWorkedOn     String?   @db.Text
  behaviorsObserved String?   @db.Text
  reinforcersUsed   String?   @db.Text
  generalComments   String?   @db.Text
  payloadJson       Json?
  submittedAt       DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  timeEntry  TimeEntry  @relation(fields: [timeEntryId], references: [id], onDelete: Cascade)
  rbtProfile RBTProfile @relation(fields: [rbtProfileId], references: [id], onDelete: Cascade)

  @@map("session_notes")
}

model LeaveRequest {
  id           String             @id @default(cuid())
  rbtProfileId String
  startDate    DateTime
  endDate      DateTime
  type         LeaveType
  reason       String?            @db.Text
  status       LeaveRequestStatus @default(PENDING)
  adminNotes   String?            @db.Text
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  rbtProfile RBTProfile @relation(fields: [rbtProfileId], references: [id], onDelete: Cascade)

  @@map("leave_requests")
}

model AvailabilitySlot {
  id           String   @id @default(cuid())
  rbtProfileId String
  dayOfWeek    Int // 0 = Sunday, 1 = Monday, ..., 6 = Saturday
  hour         Int // 14 to 21 (representing 2 PM-3 PM, 3 PM-4 PM, ..., 9 PM-10 PM)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  rbtProfile RBTProfile @relation(fields: [rbtProfileId], references: [id], onDelete: Cascade)

  @@unique([rbtProfileId, dayOfWeek, hour])
  @@map("availability_slots")
}

model InterviewNotes {
  id            String @id @default(cuid())
  interviewId   String @unique
  rbtProfileId  String
  scriptVersion String @default("1.0")

  // Structured answers for each question
  greetingAnswer        String? @db.Text
  basicInfoAnswer       String? @db.Text
  experienceAnswer      String? @db.Text
  heardAboutAnswer      String? @db.Text
  abaPlatformsAnswer    String? @db.Text
  communicationAnswer   String? @db.Text
  availabilityAnswer    String? @db.Text
  payExpectationsAnswer String? @db.Text
  previousCompanyAnswer String? @db.Text
  expectationsAnswer    String? @db.Text
  closingNotes          String? @db.Text

  // Additional structured fields for basic info
  fullName       String?
  email          String?
  birthdate      String?
  currentAddress String? @db.Text
  phoneNumber    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  interview  Interview  @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  rbtProfile RBTProfile @relation(fields: [rbtProfileId], references: [id], onDelete: Cascade)

  @@map("interview_notes")
}

model InterviewScorecard {
  id              String   @id @default(cuid())
  interviewId     String
  createdByUserId String
  scores          Json     @default("{}") // { communication: 4, adaptability: 3, ... }
  comments        Json     @default("{}") // { communication: "...", ... }
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  interview     Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  createdByUser User      @relation(fields: [createdByUserId], references: [id], onDelete: Cascade)

  @@unique([interviewId, createdByUserId])
  @@index([interviewId])
  @@map("interview_scorecards")
}

model RBTDocument {
  id           String   @id @default(cuid())
  rbtProfileId String
  fileName     String
  fileType     String // MIME type
  fileData     String   @db.Text // base64 encoded file (empty when filePath is set)
  filePath     String?  @db.Text // Supabase storage path for application uploads
  documentType String? // 'RESUME', 'RBT_CERTIFICATE', 'CPR_CARD', 'OTHER'
  uploadedAt   DateTime @default(now())

  rbtProfile RBTProfile @relation(fields: [rbtProfileId], references: [id], onDelete: Cascade)

  @@map("rbt_documents")
}

model OnboardingDocument {
  id        String                 @id @default(cuid())
  title     String
  slug      String                 @unique
  type      OnboardingDocumentType
  pdfUrl    String?                @db.Text // URL or path to the PDF file
  pdfData   String?                @db.Text // base64 encoded PDF (alternative to pdfUrl)
  sortOrder Int                    @default(0)
  isActive  Boolean                @default(true)
  createdAt DateTime               @default(now())
  updatedAt DateTime               @updatedAt

  completions OnboardingCompletion[]

  @@map("onboarding_documents")
}

model OnboardingCompletion {
  id                 String                     @id @default(cuid())
  rbtProfileId       String
  documentId         String
  status             OnboardingCompletionStatus @default(NOT_STARTED)
  completedAt        DateTime?
  acknowledgmentJson Json? // Stores acknowledgment data (name, checkboxes, timestamp, etc.)
  signedPdfUrl       String?                    @db.Text // URL or path to the signed/completed PDF (Supabase Storage path)
  signedPdfData      String?                    @db.Text // base64 encoded signed PDF (legacy/backward compatibility)
  storageBucket      String? // Supabase Storage bucket name (e.g., 'onboarding-documents')
  fieldValues        Json? // Stores extracted field values for debugging/audit
  draftData          Json? // Stores draft form field data for fillable PDFs
  createdAt          DateTime                   @default(now())
  updatedAt          DateTime                   @updatedAt

  rbtProfile RBTProfile         @relation(fields: [rbtProfileId], references: [id], onDelete: Cascade)
  document   OnboardingDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([rbtProfileId, documentId])
  @@map("onboarding_completions")
}

model CandidateApplicationDraft {
  id        String    @id @default(cuid())
  email     String
  dataJson  Json
  token     String    @unique
  status    String    @default("IN_PROGRESS")
  expiresAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([email, status])
  @@index([token])
  @@map("candidate_application_drafts")
}

model RBTAuditLog {
  id           String   @id @default(cuid())
  rbtProfileId String
  auditType    String // 'PHONE_CALL', 'EMAIL', 'NOTE', etc.
  dateTime     DateTime
  notes        String?  @db.Text
  createdBy    String? // Admin user email or name
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  rbtProfile RBTProfile @relation(fields: [rbtProfileId], references: [id], onDelete: Cascade)

  @@index([rbtProfileId, dateTime])
  @@map("rbt_audit_logs")
}

model ActivityLog {
  id           String       @id @default(cuid())
  userId       String
  activityType ActivityType
  action       String
  resourceType String?
  resourceId   String?
  url          String?
  metadata     Json?
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime     @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([activityType])
  @@index([createdAt])
  @@index([resourceType, resourceId])
  @@map("activity_logs")
}

// --- Employees and Candidates (non-RBT) ---

model BCBAProfile {
  id                     String    @id @default(cuid())
  fullName               String
  email                  String?
  phone                  String?
  certificationNumber    String?
  certificationExpiresAt DateTime?
  isSupervisor           Boolean   @default(false)
  preferredRegions       String?   @db.Text
  notes                  String?   @db.Text
  status                 String? // e.g. Active, Inactive
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  @@map("bcba_profiles")
}

model BillingProfile {
  id         String    @id @default(cuid())
  fullName   String
  email      String?
  phone      String?
  title      String?
  department String?
  startDate  DateTime?
  notes      String?   @db.Text
  status     String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@map("billing_profiles")
}

model MarketingProfile {
  id        String   @id @default(cuid())
  fullName  String
  email     String?
  phone     String?
  title     String?
  campaigns String?  @db.Text
  notes     String?  @db.Text
  status    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("marketing_profiles")
}

model CallCenterProfile {
  id        String   @id @default(cuid())
  fullName  String
  email     String?
  phone     String?
  title     String?
  extension String?
  notes     String?  @db.Text
  status    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("call_center_profiles")
}

model DevTeam {
  id          String   @id @default(cuid())
  name        String
  description String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members DevTeamMember[]

  @@map("dev_teams")
}

model DevTeamMember {
  id        String   @id @default(cuid())
  devTeamId String
  fullName  String
  email     String?
  phone     String?
  role      String? // title/role
  notes     String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  devTeam DevTeam @relation(fields: [devTeamId], references: [id], onDelete: Cascade)

  @@map("dev_team_members")
}

model StaffHoursLog {
  id           String            @id @default(cuid())
  employeeType StaffHoursLogType
  referenceId  String // ID of BCBAProfile, BillingProfile, etc., or DevTeamMember
  periodStart  DateTime          @db.Date
  periodEnd    DateTime          @db.Date
  hours        Float
  note         String?           @db.Text
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([employeeType, referenceId])
  @@map("staff_hours_logs")
}

// --- ABA Compliance Employment & Clinical Layer ---

model Employee {
  id           String       @id @default(cuid())
  employeeType EmployeeType
  /// ID of RBTProfile, BCBAProfile, BillingProfile, MarketingProfile, CallCenterProfile, or DevTeamMember
  referenceId  String
  userId       String?
  displayName  String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  user                   User?                @relation("UserEmployee", fields: [userId], references: [id])
  roles                  EmployeeRole[]
  documents              EmploymentDocument[]
  credentials            Credential[]
  clinicalServiceLogs    ClinicalServiceLog[]
  supervisedClinicalLogs ClinicalServiceLog[] @relation("SupervisorEmployee")
  supervisionAsRbt       SupervisionEvent[]   @relation("SupervisionAsRbt")
  supervisionAsBcba      SupervisionEvent[]   @relation("SupervisionAsBcba")
  complianceAlerts       ComplianceAlert[]

  @@index([employeeType, referenceId])
  @@map("employees")
}

model EmployeeRole {
  id         String       @id @default(cuid())
  employeeId String
  role       EmployeeType
  isPrimary  Boolean      @default(false)
  createdAt  DateTime     @default(now())

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@map("employee_roles")
}

model EmploymentDocument {
  id              String         @id @default(cuid())
  employeeId      String
  docType         DocumentType
  fileUrl         String?        @db.Text
  fileHash        String?
  issuedAt        DateTime?
  expiresAt       DateTime?
  status          DocumentStatus @default(ACTIVE)
  notes           String?        @db.Text
  createdByUserId String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  employee  Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  createdBy User?    @relation("UserEmploymentDocuments", fields: [createdByUserId], references: [id])

  @@index([employeeId])
  @@index([docType])
  @@index([expiresAt])
  @@map("documents")
}

model Credential {
  id                 String                       @id @default(cuid())
  employeeId         String
  credentialType     CredentialType
  credentialNumber   String
  state              String?
  issuedAt           DateTime?
  expiresAt          DateTime?
  verificationStatus CredentialVerificationStatus @default(UNVERIFIED)
  verifiedAt         DateTime?
  verifiedByUserId   String?
  createdAt          DateTime                     @default(now())
  updatedAt          DateTime                     @updatedAt

  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  verifiedBy User?    @relation("UserVerifiedCredentials", fields: [verifiedByUserId], references: [id])

  @@index([employeeId, credentialType])
  @@index([expiresAt])
  @@index([verificationStatus])
  @@map("credentials")
}

model Client {
  id         String    @id @default(cuid())
  fullName   String
  dob        DateTime?
  externalId String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  authorizations      PayerAuthorization[]
  clinicalServiceLogs ClinicalServiceLog[]
  supervisionEvents   SupervisionEvent[]

  @@map("clients")
}

enum PayerAuthorizationStatus {
  ACTIVE
  EXPIRED
  EXHAUSTED
}

model PayerAuthorization {
  id              String                   @id @default(cuid())
  clientId        String
  payerName       String
  authNumber      String
  cptCode         String
  unitsAuthorized Int
  unitsUsed       Int                      @default(0)
  startDate       DateTime                 @db.Date
  endDate         DateTime                 @db.Date
  status          PayerAuthorizationStatus @default(ACTIVE)
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt

  client           Client               @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clinicalServices ClinicalServiceLog[]

  @@index([clientId])
  @@index([authNumber])
  @@index([endDate])
  @@index([status])
  @@map("payer_authorizations")
}

model ClinicalServiceLog {
  id                   String          @id @default(cuid())
  employeeId           String
  supervisorEmployeeId String?
  clientId             String
  serviceDate          DateTime        @db.Date
  startTime            DateTime?
  endTime              DateTime?
  minutes              Int?
  location             ServiceLocation
  cptCode              String
  isBillable           Boolean         @default(true)
  payerAuthorizationId String?
  units                Int?
  note                 String?         @db.Text
  createdByUserId      String?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt

  employee           Employee            @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  supervisorEmployee Employee?           @relation("SupervisorEmployee", fields: [supervisorEmployeeId], references: [id])
  client             Client              @relation(fields: [clientId], references: [id], onDelete: Cascade)
  payerAuthorization PayerAuthorization? @relation(fields: [payerAuthorizationId], references: [id])
  createdBy          User?               @relation("UserCreatedClinicalLogs", fields: [createdByUserId], references: [id])
  supervisionEvents  SupervisionEvent[]  @relation("LinkedServiceLog")

  @@index([employeeId, serviceDate])
  @@index([clientId, serviceDate])
  @@index([cptCode])
  @@map("clinical_service_logs")
}

model SupervisionEvent {
  id                 String          @id @default(cuid())
  rbtEmployeeId      String
  bcbaEmployeeId     String
  clientId           String?
  date               DateTime        @db.Date
  minutes            Int
  supervisionType    SupervisionType
  linkedServiceLogId String?
  note               String?         @db.Text
  createdAt          DateTime        @default(now())
  createdByUserId    String?

  rbtEmployee      Employee            @relation("SupervisionAsRbt", fields: [rbtEmployeeId], references: [id], onDelete: Cascade)
  bcbaEmployee     Employee            @relation("SupervisionAsBcba", fields: [bcbaEmployeeId], references: [id], onDelete: Cascade)
  client           Client?             @relation(fields: [clientId], references: [id])
  linkedServiceLog ClinicalServiceLog? @relation("LinkedServiceLog", fields: [linkedServiceLogId], references: [id])
  createdBy        User?               @relation("UserCreatedSupervisionEvents", fields: [createdByUserId], references: [id])

  @@index([rbtEmployeeId, date])
  @@index([bcbaEmployeeId, date])
  @@map("supervision_events")
}

model ComplianceAlert {
  id               String              @id @default(cuid())
  employeeId       String?
  alertType        ComplianceAlertType
  severity         ComplianceSeverity
  message          String              @db.Text
  dueAt            DateTime?
  resolvedAt       DateTime?
  resolvedByUserId String?
  createdAt        DateTime            @default(now())

  employee   Employee? @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  resolvedBy User?    @relation("UserResolvedComplianceAlerts", fields: [resolvedByUserId], references: [id])

  @@index([employeeId, resolvedAt])
  @@index([alertType])
  @@index([severity])
  @@map("compliance_alerts")
}

model AuditLog {
  id          String      @id @default(cuid())
  actorUserId String?
  entityType  String
  entityId    String
  action      AuditAction
  diff        Json?
  createdAt   DateTime    @default(now())

  actor User? @relation("UserAuditLogs", fields: [actorUserId], references: [id])

  @@index([entityType, entityId])
  @@map("audit_logs")
}

model CompanySetting {
  key       String   @id
  value     Json
  updatedAt DateTime @default(now())

  @@map("company_settings")
}
