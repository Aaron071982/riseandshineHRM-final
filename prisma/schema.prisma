  rbtProfile   RBTProfile?      @relation(fields: [rbtProfileId], references: [id], onDelete: SetNull)
  payrollOnly  PayrollOnlyPerson? @relation(fields: [payrollOnlyId], references: [id], onDelete: SetNull)
  sessions     BillingSession[]

  @@index([billingCycleId])
  @@index([matchStatus])
  @@index([payrollOnlyId])
