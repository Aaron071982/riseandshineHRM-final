// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  RBT
  CANDIDATE
  BCBA
  BILLING
  MARKETING
  CALL_CENTER
  DEV
  TRAINER
}

enum TrainingSessionStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum TrainingBookingAttendanceStatus {
  BOOKED
  ATTENDED
  NO_SHOW
  CANCELLED
}

enum TrainingEmailType {
  NEW_SESSION_AVAILABLE
  BOOKING_CONFIRMATION
  REMINDER
  SESSION_CANCELLED
  COMPLETION
  SESSION_REQUEST
}

enum ArtemisSessionRequestStatus {
  OPEN
  RESOLVED
}

enum PreferredContactMethod {
  EMAIL
  TEXT
  CALL
}

enum RBTStatus {
  NEW
  REACH_OUT
  REACH_OUT_EMAIL_SENT
  TO_INTERVIEW
  INTERVIEW_SCHEDULED
  INTERVIEW_COMPLETED
  HIRED
  ONBOARDING_COMPLETED
  STALLED
  REJECTED
  FIRED
}

enum PostHireStage {
  MATCHING
  ACTIVE_DELIVERY
}

enum TerminationReason {
  PERFORMANCE
  CONDUCT
  ATTENDANCE
  POLICY_VIOLATION
  RESTRUCTURING
  END_OF_ASSIGNMENT
  VOLUNTARY
  OTHER
}

enum TerminationStatus {
  INITIATED
  PENDING_TASKS
  COMPLETED
}

enum OffboardingTaskType {
  DISABLE_HRM_ACCESS
  REVOKE_PHI_EHR_ACCESS
  DISABLE_EMAIL_SSO
  COLLECT_PROPERTY
  REASSIGN_CLIENTS
  NOTIFY_SUPERVISOR
  REMOVE_FROM_ROSTER
  CONFIRM_OPEN_NOTES
  ISSUE_195_6_NOTICE
  ISSUE_IA_12_3
  TRIGGER_COBRA
  PROCESS_FINAL_PAY
  FILE_DOCUMENTS
}

enum InterviewStatus {
  SCHEDULED
  COMPLETED
  NO_SHOW
  CANCELED
}

enum InterviewDecision {
  PENDING
  OFFERED
  REJECTED
}

enum OnboardingTaskType {
  DOWNLOAD_DOC
  UPLOAD_SIGNED_DOC
  VIDEO_COURSE
  TRAINING_LINK
  SIGNATURE
  PACKAGE_UPLOAD
  FORTY_HOUR_COURSE_CERTIFICATE
  SOCIAL_SECURITY_DOCUMENT
}

enum ShiftStatus {
  SCHEDULED
  COMPLETED
  CANCELED
}

enum TimeEntrySource {
  MOBILE_APP
  WEB_MANUAL
}

enum SignatureStatus {
  SIGNED
  MISSING
  NA
}

enum LeaveType {
  SICK
  VACATION
  PERSONAL
  OTHER
}

enum LeaveRequestStatus {
  PENDING
  APPROVED
  DENIED
}

enum EmailTemplateType {
  REACH_OUT
  APPLICATION_REVIEWED
  INTERVIEW_INVITE
  OFFER
  REJECTION
  MISSING_ONBOARDING
  SOCIAL_SECURITY_UPLOAD_REMINDER
  DOCUMENT_SIGNATURE_RECEIPT
}

enum OnboardingDocumentType {
  ACKNOWLEDGMENT
  FILLABLE_PDF
}

enum OnboardingDocumentCategory {
  ESIGN_ONLY
  DOWNLOAD_REUPLOAD
  HR_INITIATED
  POST_ASSIGNMENT
}

enum OnboardingFlowType {
  ESIGN
  NOTICE
  NATIVE_FORM
  UPLOAD
  TRAINING_QUIZ
  BOOKING
  ADMIN_ONLY
}

enum OnboardingTier {
  TIER_A
  TIER_B
  ACTIVATION
}

enum SupervisionContractStatus {
  PENDING_RBT
  PENDING_BCBA
  COUNTERSIGNED
}

enum HRTaskStatus {
  PENDING_HR
  PENDING_BT
  PENDING_HR_SIGNOFF
  COMPLETE
}

enum FolderType {
  RBT_CERTIFICATE
  PERSONAL_DOCUMENTS
  ACKNOWLEDGMENT_FORMS
  COMPLETED_ONBOARDING_FORMS
}

enum OnboardingCompletionStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

enum RBTMessageSenderRole {
  RBT
  ADMIN
}

enum ApplicationSource {
  ADMIN_CREATED
  PUBLIC_APPLICATION
}

enum Ethnicity {
  WHITE
  ASIAN
  BLACK
  HISPANIC
  SOUTH_ASIAN
  MIDDLE_EASTERN
}

enum ActivityType {
  PAGE_VIEW
  LINK_CLICK
  BUTTON_CLICK
  FORM_SUBMISSION
  LOGIN
  LOGOUT
  MCP_TOOL_CALL
}

// Employee types for filtering (Dev team is represented by DevTeam/DevTeamMember)
enum EmployeeType {
  RBT
  BCBA
  BILLING
  MARKETING
  CALL_CENTER
  DEV
}

enum DocumentStatus {
  ACTIVE
  EXPIRED
  REPLACED
}

enum DocumentType {
  OFFER_LETTER
  EMPLOYMENT_AGREEMENT
  CONTRACTOR_AGREEMENT
  NDA
  HIPAA_ACK
  CONFIDENTIALITY
  NON_COMPETE
  W4
  I9
  DIRECT_DEPOSIT
  BACKGROUND_CHECK
  CPR_CERT
  TB_CLEARANCE
  RBT_40_HR_CERT
  RBT_COMPETENCY_ASSESSMENT
  BCBA_CERTIFICATE
  MALPRACTICE_POLICY
  CAQH_CONFIRMATION
  CREDENTIALING_APPROVAL_LETTER
}

enum CredentialType {
  BACB_ID
  RBT_CERT
  BCBA_CERT
  STATE_LICENSE
  NPI
  MEDICAID_PROVIDER_ID
  CAQH_ID
  MALPRACTICE_INSURANCE
}

enum CredentialVerificationStatus {
  UNVERIFIED
  VERIFIED
  REJECTED
}

enum ServiceLocation {
  IN_HOME
  CLINIC
  TELEHEALTH
  SCHOOL
  COMMUNITY
}

enum SupervisionType {
  DIRECT_OBSERVATION
  CLIENT_MEETING
  PARENT_TRAINING
  TEAM_MEETING
  OTHER
}

enum ComplianceAlertType {
  DOC_EXPIRING
  CREDENTIAL_EXPIRING
  UNDER_SUPERVISION_5_PERCENT
  AUTH_EXPIRING
  AUTH_EXHAUSTED
}

enum ComplianceSeverity {
  INFO
  WARN
  BLOCKER
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
}

// For StaffHoursLog: which type of profile/member the log refers to
enum StaffHoursLogType {
  BCBA
  BILLING
  MARKETING
  CALL_CENTER
  DEV_TEAM_MEMBER
}

enum BillingCycleStatus {
  DRAFT
  REVIEW
  FINALIZED
  PAID
}

enum BillingMatchStatus {
  MATCHED
  PAYROLL_ONLY
  NEEDS_REVIEW
  UNMATCHED
  IGNORED
}

model User {
  id          String   @id @default(cuid())
  name        String?
  phoneNumber String?  @unique
  email       String?  @unique
  role        UserRole @default(CANDIDATE)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  rbtProfile                 RBTProfile?
  profile                    UserProfile?
  sessions                   Session[]
  activities                 ActivityLog[]
  interviewScorecards        InterviewScorecard[]
  claimedInterviews          Interview[]                 @relation("InterviewClaimedBy")
  employees                  Employee[]                  @relation("UserEmployee")
  employmentDocuments        EmploymentDocument[]        @relation("UserEmploymentDocuments")
  verifiedCredentials        Credential[]                @relation("UserVerifiedCredentials")
  createdClinicalLogs        ClinicalServiceLog[]        @relation("UserCreatedClinicalLogs")
  createdSupervisionEvents   SupervisionEvent[]          @relation("UserCreatedSupervisionEvents")
  resolvedComplianceAlerts   ComplianceAlert[]           @relation("UserResolvedComplianceAlerts")
  auditLogs                  AuditLog[]                  @relation("UserAuditLogs")
  adminNotifications         AdminNotification[]
  interviewerSettings        InterviewerSettings?
  interviewerAvailability    InterviewerAvailability[]
  adminAvailability          AdminAvailability[]
  adminAvailabilityOverrides AdminAvailabilityOverride[]
  adminCalendarNotes         AdminCalendarNote[]
  adminStatus                AdminStatus?
  interviewSlots             InterviewSlot[]             @relation("InterviewSlotInterviewer")
  schedulingExclusions       SchedulingExclusion[]       @relation("SchedulingExcludedByUser")
  linkedOrgNodes             OrgNode[]                   @relation("OrgNodeLinkedUser")
  hostedTrainingSessions     TrainingSession[]           @relation("TrainingSessionHost")
  trainingBookingsMarked     TrainingBooking[]           @relation("TrainingBookingMarkedBy")
  billingCyclesUploaded      BillingCycle[]              @relation("BillingCycleUploadedBy")
  billingCyclesFinalized     BillingCycle[]              @relation("BillingCycleFinalizedBy")
  emailBlastsSent            EmailBlastCampaign[]        @relation("EmailBlastSentBy")
  artemisSessionRequestsResolved ArtemisSessionRequest[] @relation("ArtemisSessionRequestResolvedBy")
  terminationsDecided          Termination[]             @relation("TerminationDecisionMaker")
  rbtScheduleAssignmentsCreated RbtScheduleAssignment[]  @relation("RbtScheduleAssignmentCreatedBy")
  payrollRunsUploaded           PayrollRun[]             @relation("PayrollRunUploadedBy")
  companyDocumentsUploaded      CompanyDocument[]        @relation("CompanyDocumentUploadedBy")

  @@map("users")
}

model AdminAvailability {
  id          String   @id @default(cuid())
  userId      String
  dayOfWeek   Int
  startHour   Int
  startMinute Int
  endHour     Int
  endMinute   Int
  label       String?
  color       String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([dayOfWeek])
  @@index([userId, dayOfWeek])
  @@map("admin_availability")
}

model AdminAvailabilityOverride {
  id           String   @id @default(cuid())
  userId       String
  date         DateTime @db.Date
  overrideType String
  startHour    Int?
  startMinute  Int?
  endHour      Int?
  endMinute    Int?
  reason       String?  @db.Text
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([date])
  @@index([userId, date])
  @@map("admin_availability_overrides")
}

model AdminCalendarNote {
  id        String   @id @default(cuid())
  userId    String
  date      DateTime @db.Date
  content   String   @db.Text
  color     String?
  isPinned  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([date])
  @@index([userId, date])
  @@map("admin_calendar_notes")
}

model AdminStatus {
  id              String    @id @default(cuid())
  userId          String    @unique
  status          String
  statusEmoji     String?
  statusMessage   String?   @db.Text
  statusExpiresAt DateTime?
  lastSeenAt      DateTime  @default(now())
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([lastSeenAt])
  @@map("admin_status")
}

/// Company hierarchy / org chart (admin-managed tree).
model OrgNode {
  id            String    @id @default(cuid())
  parentId      String?
  parent        OrgNode?  @relation("OrgNodeHierarchy", fields: [parentId], references: [id], onDelete: Restrict)
  children      OrgNode[] @relation("OrgNodeHierarchy")
  name          String
  title         String
  department    String?
  /// Subgroup within department (e.g. Recruiting under HR).
  subDepartment String?
  email         String?
  phone         String?
  linkedUserId  String?
  linkedUser    User?     @relation("OrgNodeLinkedUser", fields: [linkedUserId], references: [id], onDelete: SetNull)
  avatarColor   String    @default("#f97316")
  sortOrder     Int       @default(0)
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([parentId])
  @@index([linkedUserId])
  @@index([parentId, sortOrder])
  @@index([department, subDepartment])
  @@map("org_nodes")
}

model AdminNotification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  message   String   @db.Text
  linkUrl   String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@map("admin_notifications")
}

/// Reserved for future profile feature. Currently only referenced as resourceType in activity log; no code path creates/updates.
model UserProfile {
  id                           String                  @id @default(cuid())
  userId                       String                  @unique
  fullName                     String?
  preferredName                String?
  phone                        String?
  address                      String?
  timezone                     String?
  preferredContactMethod       PreferredContactMethod?
  bio                          String?                 @db.Text
  skills                       String[]                @default([])
  languages                    String[]                @default([])
  emergencyContactName         String?
  emergencyContactRelationship String?
  emergencyContactPhone        String?
  employeeId                   String?
  startDate                    DateTime?
  department                   String?
  title                        String?
  rbtCertificationNumber       String?
  rbtCertificationExpiresAt    DateTime?
  themePreference              String? // "light" | "dark" | "system"
  eSignConsentGiven            Boolean                 @default(false)
  eSignConsentTimestamp        DateTime?
  createdAt                    DateTime                @default(now())
  updatedAt                    DateTime                @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

model Session {
  id           String    @id @default(cuid())
  userId       String
  token        String    @unique
  expiresAt    DateTime
  device       String?
  browser      String?
  ipAddress    String?
  lastActiveAt DateTime?
  createdAt    DateTime  @default(now())
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model OtpCode {
  id             String   @id @default(cuid())
  phoneNumber    String?
  email          String?
  code           String
  expiresAt      DateTime
  createdAt      DateTime @default(now())
  used           Boolean  @default(false)
  failedAttempts Int      @default(0)

  @@index([phoneNumber, code])
  @@index([email, code])
  @@map("otp_codes")
}

model OtpRateLimit {
  id          String   @id @default(cuid())
  key         String
  windowStart DateTime
  count       Int      @default(1)
  createdAt   DateTime @default(now())

  @@unique([key, windowStart])
  @@index([key, windowStart])
  @@map("otp_rate_limits")
}

model RBTProfile {
  id                       String             @id @default(cuid())
  userId                   String             @unique
  firstName                String
  lastName                 String
  phoneNumber              String
  email                    String?
  locationCity             String?
  locationState            String?
  zipCode                  String?
  addressLine1             String?
  addressLine2             String?
  preferredServiceArea     String?
  notes                    String?
  gender                   String?
  ethnicity                Ethnicity?
  fortyHourCourseCompleted Boolean            @default(false)
  status                   RBTStatus          @default(NEW)
  scheduleCompleted        Boolean            @default(false)
  source                   ApplicationSource? @default(ADMIN_CREATED)
  submittedAt              DateTime?
  resumeUrl                String?            @db.Text
  resumeFileName           String?
  resumeMimeType           String?
  resumeSize               Int?
  availabilityJson         Json?
  languagesJson            Json?
  experienceYears          Int?
  experienceYearsDisplay   String?
  preferredAgeGroupsJson   Json?
  authorizedToWork         Boolean?
  canPassBackgroundCheck   Boolean?
  cprFirstAidCertified     String?
  transportation           Boolean?
  preferredHoursRange      String?
  schedulingToken          String?            @unique
  latitude                 Float?
  longitude                Float?
  createdAt                DateTime           @default(now())
  updatedAt                DateTime           @updatedAt

  user                        User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  interviews                  Interview[]
  onboardingTasks             OnboardingTask[]
  shifts                      Shift[]
  timeEntries                 TimeEntry[]
  leaveRequests               LeaveRequest[]
  interviewEmailLogs          InterviewEmailLog[]
  availabilitySlots           AvailabilitySlot[]
  documents                   RBTDocument[]
  interviewNotes              InterviewNotes[]
  onboardingCompletions       OnboardingCompletion[]
  signatureCertificates       SignatureCertificate[]
  auditLogs                   RBTAuditLog[]
  clientAssignments           ClientAssignment[]
  sessionNotes                SessionNote[]
  messages                    RBTMessage[]
  interviewSlotsBooked        InterviewSlot[]
  schedulingExclusions        SchedulingExclusion[]
  artemisTrainingCompleted    Boolean                @default(false)
  artemisTrainingCompletedAt  DateTime?
  artemisTrainingSessionId    String?
  artemisTrainingSession      TrainingSession?       @relation("ArtemisCompletionSession", fields: [artemisTrainingSessionId], references: [id], onDelete: SetNull)
  trainingBookings            TrainingBooking[]
  trainingEmailLogs           TrainingEmailLog[]
  artemisSessionRequests      ArtemisSessionRequest[]
  hrDocumentTasks             HRDocumentTask[]
  employeeDocumentFolders     EmployeeDocumentFolder[]
  tierACompletedAt            DateTime?
  tierBCompletedAt            DateTime?
  fullyActivatedAt            DateTime?
  backgroundCheckClearedAt    DateTime?
  backgroundCheckClearedBy    String?
  supervisionCountersignedAt  DateTime?
  supervisionCountersignedBy  String?
  supervisionContractStatus   SupervisionContractStatus?
  postHireStage               PostHireStage?
  activeWorkingSince          DateTime?
  activeWorkingManualOverride Boolean                    @default(false)
  terminationReason           String?                    @db.Text
  terminatedAt                DateTime?
  terminatedBy                String?
  quizAttempts                OnboardingQuizAttempt[]
  quizCertificates            OnboardingQuizCertificate[]
  oigScreeningLogs            OigScreeningLog[]
  hourlyPayRate               Float?
  artemisProviderName         String?
  /// Remembered "Last, First" from payroll register uploads (like artemisProviderName)
  payrollName                 String?
  payRateUpdatedAt            DateTime?
  payRateUpdatedBy            String?
  billingEntries              BillingEntry[]
  billingHoursConfirmations   BillingHoursConfirmation[]
  emailBlastSendLogs          EmailBlastSendLog[]
  termination                 Termination?
  scheduleAssignments         RbtScheduleAssignment[]
  payStatements               RbtPayStatement[]
  payrollRunEntries           PayrollRunEntry[]
  companyDocumentRecipients   CompanyDocumentRecipient[]

  @@index([artemisTrainingCompleted])
  @@index([postHireStage])
  @@map("rbt_profiles")
}

model TrainingSession {
  id               String                @id @default(cuid())
  hostUserId       String
  title            String                @default("Artemis Training")
  description      String?               @db.Text
  sessionDate      DateTime              @db.Date
  startTime        DateTime
  endTime          DateTime
  meetingUrl       String                @db.Text
  maxAttendees     Int                   @default(10)
  currentAttendees Int                   @default(0)
  status           TrainingSessionStatus @default(SCHEDULED)
  notes            String?               @db.Text
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  host              User               @relation("TrainingSessionHost", fields: [hostUserId], references: [id], onDelete: Cascade)
  bookings          TrainingBooking[]
  emailLogs         TrainingEmailLog[]
  completedProfiles RBTProfile[]       @relation("ArtemisCompletionSession")

  @@index([sessionDate])
  @@index([status])
  @@index([hostUserId])
  @@index([startTime])
  @@map("training_sessions")
}

model TrainingBooking {
  id                String                          @id @default(cuid())
  trainingSessionId String
  rbtProfileId      String
  bookedAt          DateTime                        @default(now())
  attendanceStatus  TrainingBookingAttendanceStatus @default(BOOKED)
  markedAttendedBy  String?
  markedAttendedAt  DateTime?
  createdAt         DateTime                        @default(now())
  updatedAt         DateTime                        @updatedAt

  trainingSession TrainingSession @relation(fields: [trainingSessionId], references: [id], onDelete: Cascade)
  rbtProfile      RBTProfile      @relation(fields: [rbtProfileId], references: [id], onDelete: Cascade)
  markedByUser    User?           @relation("TrainingBookingMarkedBy", fields: [markedAttendedBy], references: [id], onDelete: SetNull)

  @@unique([trainingSessionId, rbtProfileId])
  @@index([rbtProfileId])
  @@index([trainingSessionId])
  @@index([attendanceStatus])
  @@map("training_bookings")
}

model TrainingEmailLog {
  id                String            @id @default(cuid())
  trainingSessionId String
  rbtProfileId      String
  emailType         TrainingEmailType
  sentAt            DateTime          @default(now())
  createdAt         DateTime          @default(now())

  trainingSession TrainingSession @relation(fields: [trainingSessionId], references: [id], onDelete: Cascade)
  rbtProfile      RBTProfile      @relation(fields: [rbtProfileId], references: [id], onDelete: Cascade)

  @@index([trainingSessionId])
  @@index([rbtProfileId])
  @@index([emailType, sentAt])
  @@map("training_email_log")
}

model ArtemisSessionRequest {
  id               String                      @id @default(cuid())
  rbtProfileId     String
  message          String?                     @db.Text
  status           ArtemisSessionRequestStatus @default(OPEN)
  createdAt        DateTime                    @default(now())
  resolvedAt       DateTime?
  resolvedByUserId String?

  rbtProfile RBTProfile @relation(fields: [rbtProfileId], references: [id], onDelete: Cascade)
  resolvedBy User?      @relation("ArtemisSessionRequestResolvedBy", fields: [resolvedByUserId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([rbtProfileId])
  @@map("artemis_session_requests")
}

model SchedulingExclusion {
  id               String    @id @default(cuid())
  rbtProfileId     String
  excludedByUserId String
  reason           String?   @db.Text
  expiresAt        DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  rbtProfile     RBTProfile @relation(fields: [rbtProfileId], references: [id], onDelete: Cascade)
  excludedByUser User       @relation("SchedulingExcludedByUser", fields: [excludedByUserId], references: [id], onDelete: Cascade)

  @@unique([rbtProfileId])
  @@index([rbtProfileId])
  @@index([excludedByUserId])
  @@index([expiresAt])
  @@map("scheduling_exclusions")
}

// Scheduling: clients (e.g. for RBT–client matching and assignments)
model SchedulingClient {
  id                    String   @id @default(cuid())
  name                  String
  addressLine1          String?
  addressLine2          String?
  city                  String?
  state                 String?
  zip                   String?
  preferredRbtEthnicity String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  assignments ClientAssignment[]

  @@map("scheduling_clients")
}

// RBT–client assignment: which days and time range (e.g. Mon/Tue/Wed 4–7 PM)
model ClientAssignment {
  id                 String   @id @default(cuid())
  rbtProfileId       String
  schedulingClientId String
  daysOfWeek         Int[] // 0=Sunday, 1=Monday, ..., 6=Saturday
  timeStart          String? // e.g. "16:00" or "4:00 PM"
  timeEnd            String? // e.g. "19:00" or "7:00 PM"
  hourlyRate         Decimal? @db.Decimal(10, 2) // RBT pay per hour for this client (USD)
  notes              String?  @db.Text
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  rbtProfile RBTProfile       @relation(fields: [rbtProfileId], references: [id], onDelete: Cascade)
  client     SchedulingClient @relation(fields: [schedulingClientId], references: [id], onDelete: Cascade)

  @@index([rbtProfileId])
  @@index([schedulingClientId])
  @@map("client_assignments")
}

/// Interview reminder columns: reminderSentAt = 30-minute reminder sent at (cron: send-interview-reminders).
/// reminder_15m_sent_at = 15-minute reminder sent at (cron: interview-reminders, env INTERVIEW_REMINDER_MINUTES).
model Interview {
  id                   String            @id @default(cuid())
  rbtProfileId         String
  scheduledAt          DateTime
  durationMinutes      Int               @default(30)
  interviewerName      String
  status               InterviewStatus   @default(SCHEDULED)
  decision             InterviewDecision @default(PENDING)
  meetingUrl           String?
  notes                String?
  reminderSentAt       DateTime? // 30m reminder sent at
  reminder_15m_sent_at DateTime? // 15m reminder sent at
  reminder_1hr_sent_at DateTime? // 1hr reminder sent at
  dailyDigestDate      DateTime?         @db.Date // last date included in daily digest
  claimedByUserId      String? // admin who claimed this interview
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  rbtProfile     RBTProfile           @relation(fields: [rbtProfileId], references: [id], onDelete: Cascade)
  claimedBy      User?                @relation("InterviewClaimedBy", fields: [claimedByUserId], references: [id], onDelete: SetNull)
  interviewNotes InterviewNotes?
  scorecards     InterviewScorecard[]

  @@index([reminder_15m_sent_at])
  @@index([dailyDigestDate])
  @@index([claimedByUserId])
  @@map("interviews")
}

/// Per-admin toggle and slot rules for interview scheduling (Calendly-style).
model InterviewerSettings {
  id                      String   @id @default(cuid())
  userId                  String   @unique
  acceptInterviewBookings Boolean  @default(true)
  slotDurationMinutes     Int      @default(15)
  bufferMinutes           Int      @default(0)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

