// ─── Weekly scheduling module (recurring session slots) ─────────────────────

enum ScheduleDayOfWeek {
  MON
  TUE
  WED
  THU
  FRI
  SAT
  SUN
}

enum ScheduleSlotStatus {
  CONFIRMED
  TENTATIVE
  NEEDS_REVIEW
  CANCELLED
}

enum ScheduleTherapistRole {
  RBT
  BT
  BCBA
  BCaBA
  CLINICAL_DIRECTOR
}

model ScheduleAllowedUser {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())

  @@map("schedule_allowed_user")
}

model ScheduleTherapist {
  id        String                @id @default(cuid())
  name      String
  email     String?               @unique
  role      ScheduleTherapistRole @default(RBT)
  colorKey  Int?
  active    Boolean               @default(true)
  slots     ScheduleSessionSlot[]
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt

  @@index([active])
  @@map("therapist")
}

model ScheduleWeeklyClient {
  id                     String                @id @default(cuid())
  code                   String?               @unique
  name                   String
  insurance              String?
  bcba                   String?
  authorizedHoursPerWeek Decimal?              @db.Decimal(5, 2)
  active                 Boolean               @default(true)
  slots                  ScheduleSessionSlot[]
  createdAt              DateTime              @default(now())
  updatedAt              DateTime              @updatedAt

  @@index([active])
  @@map("schedule_client")
}

model ScheduleSessionSlot {
  id             String               @id @default(cuid())
  therapistId    String
  clientId       String
  day            ScheduleDayOfWeek
  startMin       Int
  endMin         Int
  status         ScheduleSlotStatus   @default(CONFIRMED)
  procedureCode  String               @default("97153")
  placeOfService String               @default("12-Home")
  note           String?
  createdBy      String?
  updatedBy      String?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  therapist      ScheduleTherapist     @relation(fields: [therapistId], references: [id], onDelete: Cascade)
  client         ScheduleWeeklyClient @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([therapistId, clientId, day, startMin])
  @@index([therapistId])
  @@index([clientId])
  @@index([day])
  @@map("session_slot")
}

// ─── Payroll register uploads (employee pay stubs) ───────────────────────────

enum PayrollRunStatus {
  DRAFT
  PUBLISHED
}

enum PayrollMatchStatus {
  MATCHED
  NEEDS_REVIEW
  UNMATCHED
}

/// REGISTER = flat payroll register import; YTD_SNAPSHOT = derived from cumulative YTD exports
enum PayrollSourceFormat {
  REGISTER
  YTD_SNAPSHOT
}

model PayrollRun {
  id                        String              @id @default(cuid())
  label                     String
  payDate                   DateTime            @db.Date
  periodStart               DateTime            @db.Date
  periodEnd                 DateTime            @db.Date
  sourceFileName            String?
  uploadedById              String
  employeeCount             Int                 @default(0)
  totalNetPay               Float               @default(0)
  totalGrossPay             Float               @default(0)
  status                    PayrollRunStatus    @default(DRAFT)
  sourceFormat              PayrollSourceFormat @default(REGISTER)
  /// true when amounts were derived by diffing cumulative YTD snapshots
  isDerived                 Boolean             @default(false)
  snapshotFileName          String?
  snapshotReportedAt        DateTime?
  checksumOk                Boolean             @default(true)
  importWarnings            Json?
  totalEmployeeTax          Float?
  totalEmployeeDeductions   Float?
  totalEmployerTax          Float?
  createdAt                 DateTime            @default(now())
  updatedAt                 DateTime            @updatedAt

  uploadedBy User              @relation("PayrollRunUploadedBy", fields: [uploadedById], references: [id])
  entries    PayrollRunEntry[]

  @@unique([payDate, sourceFormat])
  @@index([status])
  @@index([payDate])
  @@map("payroll_runs")
}

model PayrollRunEntry {
  id                     String             @id @default(cuid())
  payrollRunId           String
  rbtProfileId           String?
  payrollName            String
  matchStatus            PayrollMatchStatus @default(UNMATCHED)
  matchConfidence        Float              @default(0)
  totalHours             Float              @default(0)
  grossPay               Float              @default(0)
  /// Register format only; null for YTD-derived rows (UI shows —)
  adjustedGross          Float?
  empTaxTotal            Float              @default(0)
  empTaxFIT              Float              @default(0)
  empTaxSS               Float              @default(0)
  empTaxMed              Float              @default(0)
  empTaxNYIT             Float              @default(0)
  netPay                 Float              @default(0)
  /// Admin-only — never expose on employee APIs
  employerTaxTotal       Float              @default(0)
  /// Admin-only — never expose on employee APIs
  totalPayrollCost       Float              @default(0)
  isContractor           Boolean            @default(false)
  /// [{ rawType, units, gross }]
  earningsLines          Json               @default("[]")
  /// [{ rawType, amount }]
  empTaxLines            Json               @default("[]")
  empDeductionLines      Json               @default("[]")
  /// Admin-only — never expose on employee APIs
  employerTaxLines       Json               @default("[]")
  /// Admin-only — never expose on employee APIs
  employerDeductionLines Json               @default("[]")
  empDeductionTotal      Float              @default(0)
  /// NEW YOR + YONKER
  empTaxLocal            Float              @default(0)
  /// STATE-NJ and other non-NY state withholding
  empTaxStateOther       Float              @default(0)
  /// Vendor TOTAL: values cell (hours + 1099 units) — checksum only
  reportedTotalValues    Float?
  /// Cumulative YTD figure this period delta was derived from
  ytdGross               Float?
  ytdNetPay              Float?
  /// Optional vendor "ID: 20251201" line
  payrollEmployeeId      String?
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt

  payrollRun PayrollRun  @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)
  rbtProfile RBTProfile? @relation(fields: [rbtProfileId], references: [id], onDelete: SetNull)

  @@unique([payrollRunId, rbtProfileId])
  @@index([payrollRunId])
  @@index([rbtProfileId])
  @@index([matchStatus])
  @@map("payroll_run_entries")
}

// ─── Company-wide document distribution ──────────────────────────────────────

enum CompanyDocumentType {
  ACKNOWLEDGMENT
  DOWNLOAD_UPLOAD
  VIEW_ONLY
}

enum CompanyDocumentRecipientStatus {
  PENDING
  VIEWED
  SIGNED
  SUBMITTED
}

model CompanyDocument {
  id           String              @id @default(cuid())
  title        String
  description  String?             @db.Text
  fileUrl      String
  fileType     String
  documentType CompanyDocumentType
  uploadedById String
  isActive     Boolean             @default(true)
  isTest       Boolean             @default(false)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  uploadedBy User                       @relation("CompanyDocumentUploadedBy", fields: [uploadedById], references: [id])
  recipients CompanyDocumentRecipient[]

  @@index([isActive, isTest])
  @@index([createdAt])
  @@map("company_documents")
}

model CompanyDocumentRecipient {
  id                String                         @id @default(cuid())
  companyDocumentId String
  rbtProfileId      String
  status            CompanyDocumentRecipientStatus @default(PENDING)
  signedName        String?
  signedAt          DateTime?
  signatureIp       String?
  uploadedFileUrl   String?
  viewedAt          DateTime?
  submittedAt       DateTime?
  emailSentAt       DateTime?
  createdAt         DateTime                       @default(now())
  updatedAt         DateTime                       @updatedAt

  companyDocument CompanyDocument @relation(fields: [companyDocumentId], references: [id], onDelete: Cascade)
  rbtProfile      RBTProfile      @relation(fields: [rbtProfileId], references: [id], onDelete: Cascade)

  @@unique([companyDocumentId, rbtProfileId])
  @@index([rbtProfileId, status])
  @@index([companyDocumentId, status])
  @@map("company_document_recipients")
}


