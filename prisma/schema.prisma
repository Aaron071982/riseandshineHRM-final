/// Snapshot of an RBT's pay for a finalized billing cycle (immutable after finalize; updated only on re-finalize).
model RbtPayStatement {
  id                 String   @id @default(cuid())
  rbtProfileId       String
  billingCycleId     String
  periodStart        DateTime @db.Date
  periodEnd          DateTime @db.Date
  payableStatuses     String[]
  completedHours     Float    @default(0)
  readyToBillHours   Float    @default(0)
  incompleteHours    Float    @default(0)
  inProgressHours    Float    @default(0)
  scheduledHours     Float    @default(0)
  payableHours       Float    @default(0)
  hourlyRate         Float
  grossPay           Float    @default(0)
  adjustment         Float    @default(0)
  finalPay           Float    @default(0)
  status             String   @default("FINALIZED")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  rbtProfile   RBTProfile               @relation(fields: [rbtProfileId], references: [id], onDelete: Cascade)
  billingCycle BillingCycle             @relation(fields: [billingCycleId], references: [id], onDelete: Cascade)
  sessions     RbtPayStatementSession[]

  @@unique([rbtProfileId, billingCycleId])
  @@index([rbtProfileId, status])
  @@index([billingCycleId])
  @@map("rbt_pay_statements")
}

model RbtPayStatementSession {
  id             String   @id @default(cuid())
  payStatementId String
  clientName     String
  dos            DateTime @db.Date
  status         String
  hours          Float
  procedureCode  String?
  isPayable      Boolean  @default(false)

  payStatement RbtPayStatement @relation(fields: [payStatementId], references: [id], onDelete: Cascade)

  @@index([payStatementId])
  @@map("rbt_pay_statement_sessions")
}

