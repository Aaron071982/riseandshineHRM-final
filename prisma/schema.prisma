  @@map("company_settings")
}

model BillingCycle {
  id             String             @id @default(cuid())
  label          String
  periodStart    DateTime           @db.Date
  periodEnd      DateTime           @db.Date
  status         BillingCycleStatus @default(DRAFT)
  sourceFileName String?
  totalHours     Float              @default(0)
  totalGrossPay  Float              @default(0)
  rbtCount       Int                @default(0)
  uploadedById   String
  finalizedById  String?
  finalizedAt    DateTime?
  payableStatuses Json?             @default("[\"completed\",\"ready_to_bill\"]")
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  uploadedBy  User           @relation("BillingCycleUploadedBy", fields: [uploadedById], references: [id])
  finalizedBy User?          @relation("BillingCycleFinalizedBy", fields: [finalizedById], references: [id])
  entries     BillingEntry[]
  hoursConfirmations BillingHoursConfirmation[]
  payStatements RbtPayStatement[]

  @@index([status])
  @@map("billing_cycles")
}

model BillingEntry {
  id                    String             @id @default(cuid())
  billingCycleId        String
  rbtProfileId          String?
  payrollOnlyId         String?
  providerNameRaw       String
  matchStatus           BillingMatchStatus
  matchConfidence       Float              @default(0)
  suggestedRbtProfileId String?
  totalSessions         Int                @default(0)
  totalMinutes          Float              @default(0)
  totalHours            Float              @default(0)
  hourlyRate            Float?
  grossPay              Float              @default(0)
